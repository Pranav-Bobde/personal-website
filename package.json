{
  "name": "oreno-website.bts-migration",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "next-themes": "^0.4.6",
      "@orpc/server": "^1.13.14",
      "@orpc/client": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo check-types",
    "lint": "oxlint",
    "fallow": "fallow audit --base HEAD --format compact",
    "format": "oxfmt --write",
    "verify": "bun run typecheck && bun run lint && bun run fallow && bun run build",
    "dev:web": "turbo -F web dev"
  },
  "devDependencies": {
    "@oreno-website.bts-migration/config": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "fallow": "^2.82.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
